// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  MANAGER
  EMPLOYEE
}

enum SubscriptionPlan {
  BASIC
  MANAGEMENT
  COMPLETE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  OVERDUE
  CANCELED
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  SPECIFIC_WEEKDAYS
  SPECIFIC_MONTH_DAY
}

enum GoalUnit {
  BRL
  PERCENT
  NUMBER
  TASKS
  CLIENTS
  SALES
}

enum GoalPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  CUSTOM
}

enum GoalStatus {
  ON_TRACK
  ATTENTION
  LATE
  COMPLETED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE_SOON
  TASK_OVERDUE
  NEW_COMMENT
  STATUS_UPDATED
  GOAL_ATTENTION
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  OVERDUE
  CANCELED
  REFUNDED
}

enum PaymentMethodType {
  CREDIT_CARD
  PIX
  BOLETO
  TRANSFER
  DEMO
}

enum ActivityType {
  COMPANY_CREATED
  COMPANY_UPDATED
  USER_CREATED
  USER_UPDATED
  DEPARTMENT_CREATED
  DEPARTMENT_UPDATED
  TASK_CREATED
  TASK_UPDATED
  TASK_COMMENTED
  GOAL_CREATED
  GOAL_UPDATED
  SUBSCRIPTION_CHANGED
  REPORT_GENERATED
}

enum ReportSnapshotType {
  EXECUTIVE
  MONTHLY
  HEALTH
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

model PlanCatalog {
  id                String                @id @default(cuid())
  code              SubscriptionPlan      @unique
  name              String
  label             String
  description       String
  priceCents        Int
  pricePerExtraUser Int
  currency          String                @default("BRL")
  billingCycle      BillingCycle          @default(MONTHLY)
  includedUsers     Int
  maxUsers          Int?
  dashboardName     String
  isHighlighted     Boolean               @default(false)
  isActive          Boolean               @default(true)
  sortOrder         Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  features          PlanFeature[]
  subscriptions     CompanySubscription[]
}

model PlanFeature {
  id          String      @id @default(cuid())
  planId      String
  featureKey  String
  name        String
  description String?
  included    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  plan        PlanCatalog @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([planId, sortOrder])
}

model Company {
  id              String                @id @default(cuid())
  name            String
  segment         String?
  document        String?
  phone           String?
  email           String?
  city            String?
  state           String?
  employeeCount   Int?
  plan            SubscriptionPlan      @default(BASIC)
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  users           User[]
  departments     Department[]
  tasks           Task[]
  goals           Goal[]
  notifications   Notification[]
  onboarding      OnboardingStep[]
  subscriptions   CompanySubscription[]
  paymentMethods  PaymentMethod[]
  invoices        Invoice[]
  usageSnapshots  UsageSnapshot[]
  activityLogs    ActivityLog[]
  reportSnapshots ReportSnapshot[]
  supportTickets  SupportTicket[]
}

model User {
  id                 String              @id @default(cuid())
  companyId          String
  departmentId       String?
  name               String
  email              String              @unique
  passwordHash       String
  role               UserRole            @default(EMPLOYEE)
  position           String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department         Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedTasks      Task[]              @relation("TaskAssignee")
  createdTasks       Task[]              @relation("TaskCreator")
  comments           TaskComment[]
  attachments        TaskAttachment[]
  goals              Goal[]              @relation("GoalResponsible")
  notifications      Notification[]      @relation("NotificationRecipient")
  onboardingSteps    OnboardingStep[]
  activityLogs       ActivityLog[]       @relation("ActivityActor")
  taskActivities     TaskActivity[]      @relation("TaskActivityActor")
  subscriptionEvents SubscriptionEvent[] @relation("SubscriptionEventActor")
  reportSnapshots    ReportSnapshot[]    @relation("ReportSnapshotCreator")
  supportTickets     SupportTicket[]     @relation("SupportRequester")

  @@index([companyId])
  @@index([departmentId])
}

model Department {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users       User[]
  tasks       Task[]
  goals       Goal[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Task {
  id             String           @id @default(cuid())
  companyId      String
  departmentId   String
  assigneeId     String
  creatorId      String
  title          String
  description    String
  dueDate        DateTime
  priority       TaskPriority     @default(MEDIUM)
  status         TaskStatus       @default(PENDING)
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department     Department       @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  assignee       User             @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  creator        User             @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  comments       TaskComment[]
  attachments    TaskAttachment[]
  activities     TaskActivity[]
  recurrenceRule RecurrenceRule?

  @@index([companyId, status])
  @@index([companyId, priority])
  @@index([companyId, dueDate])
  @@index([departmentId])
  @@index([assigneeId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  fileName  String
  fileUrl   String
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model TaskActivity {
  id          String       @id @default(cuid())
  taskId      String
  actorId     String?
  type        ActivityType
  fromStatus  TaskStatus?
  toStatus    TaskStatus?
  description String
  createdAt   DateTime     @default(now())
  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor       User?        @relation("TaskActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([actorId])
}

model RecurrenceRule {
  id        String         @id @default(cuid())
  taskId    String         @unique
  type      RecurrenceType @default(NONE)
  weekDays  String?
  monthDay  Int?
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  task      Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Goal {
  id            String      @id @default(cuid())
  companyId     String
  departmentId  String?
  responsibleId String?
  title         String
  description   String?
  targetValue   Float
  currentValue  Float       @default(0)
  unit          GoalUnit
  period        GoalPeriod
  status        GoalStatus  @default(ON_TRACK)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  responsible   User?       @relation("GoalResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([departmentId])
  @@index([responsibleId])
}

model Notification {
  id            String           @id @default(cuid())
  companyId     String
  userId        String
  type          NotificationType
  title         String
  message       String
  isRead        Boolean          @default(false)
  link          String?
  relatedTaskId String?
  relatedGoalId String?
  createdAt     DateTime         @default(now())
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([companyId, createdAt])
}

model OnboardingStep {
  id          String    @id @default(cuid())
  companyId   String
  userId      String
  key         String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([companyId])
}

model CompanySubscription {
  id                 String              @id @default(cuid())
  companyId          String
  planId             String
  status             SubscriptionStatus  @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  canceledAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan               PlanCatalog         @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices           Invoice[]
  usageSnapshots     UsageSnapshot[]
  events             SubscriptionEvent[]

  @@index([companyId, status])
  @@index([planId])
}

model SubscriptionEvent {
  id             String              @id @default(cuid())
  subscriptionId String
  actorId        String?
  type           ActivityType
  title          String
  description    String?
  createdAt      DateTime            @default(now())
  subscription   CompanySubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  actor          User?               @relation("SubscriptionEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([subscriptionId, createdAt])
  @@index([actorId])
}

model PaymentMethod {
  id         String            @id @default(cuid())
  companyId  String
  type       PaymentMethodType
  provider   String?
  brand      String?
  last4      String?
  holderName String?
  isDefault  Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices   Invoice[]

  @@index([companyId, isDefault])
}

model Invoice {
  id              String               @id @default(cuid())
  companyId       String
  subscriptionId  String?
  paymentMethodId String?
  number          String               @unique
  status          InvoiceStatus        @default(OPEN)
  amountCents     Int
  currency        String               @default("BRL")
  dueDate         DateTime
  paidAt          DateTime?
  periodStart     DateTime
  periodEnd       DateTime
  description     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription    CompanySubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  paymentMethod   PaymentMethod?       @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([subscriptionId])
  @@index([dueDate])
}

model UsageSnapshot {
  id             String               @id @default(cuid())
  companyId      String
  subscriptionId String?
  activeUsers    Int
  departments    Int
  tasks          Int
  goals          Int
  storageMb      Int                  @default(0)
  takenAt        DateTime             @default(now())
  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription   CompanySubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([companyId, takenAt])
  @@index([subscriptionId])
}

model ActivityLog {
  id          String       @id @default(cuid())
  companyId   String
  actorId     String?
  type        ActivityType
  entityType  String
  entityId    String?
  title       String
  description String?
  metadata    String?
  createdAt   DateTime     @default(now())
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor       User?        @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
}

model ReportSnapshot {
  id          String             @id @default(cuid())
  companyId   String
  createdById String?
  type        ReportSnapshotType @default(EXECUTIVE)
  title       String
  summary     String
  healthScore Int
  payload     String
  createdAt   DateTime           @default(now())
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User?              @relation("ReportSnapshotCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([createdById])
}

model SupportTicket {
  id          String              @id @default(cuid())
  companyId   String
  requesterId String?
  title       String
  description String
  status      SupportTicketStatus @default(OPEN)
  priority    TaskPriority        @default(MEDIUM)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requester   User?               @relation("SupportRequester", fields: [requesterId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([requesterId])
}
